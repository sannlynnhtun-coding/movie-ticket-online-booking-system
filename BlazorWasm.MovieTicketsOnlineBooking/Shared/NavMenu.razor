@inject NavigationManager NavManager
@inject ThemeService ThemeService
@inject IDbService _dbService

<header class="cx-header">
    <div class="cx-header-inner">
        <!-- Logo -->
        <div class="cx-logo" @onclick="Home">
            <svg width="36" height="36" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <linearGradient id="hbg" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" stop-color="#0f172a"/>
                        <stop offset="100%" stop-color="#1e3a5f"/>
                    </linearGradient>
                    <linearGradient id="ha" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" stop-color="#38bdf8"/>
                        <stop offset="100%" stop-color="#0ea5e9"/>
                    </linearGradient>
                </defs>
                <rect width="64" height="64" rx="14" fill="url(#hbg)"/>
                <rect x="4" y="16" width="6" height="32" rx="2" fill="url(#ha)" opacity="0.9"/>
                <rect x="5" y="20" width="4" height="4" rx="1" fill="#0f172a"/>
                <rect x="5" y="28" width="4" height="4" rx="1" fill="#0f172a"/>
                <rect x="5" y="36" width="4" height="4" rx="1" fill="#0f172a"/>
                <rect x="54" y="16" width="6" height="32" rx="2" fill="url(#ha)" opacity="0.9"/>
                <rect x="55" y="20" width="4" height="4" rx="1" fill="#0f172a"/>
                <rect x="55" y="28" width="4" height="4" rx="1" fill="#0f172a"/>
                <rect x="55" y="36" width="4" height="4" rx="1" fill="#0f172a"/>
                <rect x="12" y="18" width="40" height="28" rx="5" fill="#1e293b"/>
                <circle cx="12" cy="32" r="3" fill="url(#hbg)"/>
                <circle cx="52" cy="32" r="3" fill="url(#hbg)"/>
                <circle cx="32" cy="30" r="9" fill="url(#ha)" opacity="0.95"/>
                <polygon points="29,25 40,30 29,35" fill="#0f172a"/>
                <circle cx="48" cy="20" r="3" fill="#f59e0b" opacity="0.85"/>
            </svg>
            <span class="cx-logo-text">Cinematix</span>
        </div>

        <!-- Right side controls -->
        <div style="display:flex;align-items:center;gap:12px;">
            <!-- My Tickets Button -->
            <button class="cx-btn cx-btn-ghost" style="padding:8px 16px;height:40px;"
                    title="My Tickets" @onclick="GoToMyTickets">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2z"/>
                    <path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/>
                </svg>
                <span class="hidden sm:inline">My Tickets</span>
            </button>

            <!-- Dark/Light toggle -->
            <button class="cx-theme-toggle" title="Toggle theme" @onclick="ToggleTheme">
                @if (ThemeService.IsDark)
                {
                    <!-- Sun icon for dark mode (click to go light) -->
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="4"/>
                        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
                    </svg>
                }
                else
                {
                    <!-- Moon icon for light mode (click to go dark) -->
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                }
            </button>
        </div>
    </div>
</header>

@code {
    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += StateHasChanged;
    }

    private async Task ToggleTheme()
    {
        await ThemeService.ToggleThemeAsync();
    }

    private async Task Home()
    {
        await _dbService.ClearBookingList();
        NavManager.NavigateTo("/");
    }

    private void GoToMyTickets()
    {
        NavManager.NavigateTo("/my-tickets");
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= StateHasChanged;
    }
}